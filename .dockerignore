# =============================================================================
# Root .dockerignore — applies to the repo-root build context used by the
# backend image. Must NOT exclude `docs/` (curated Copilot RAG corpus) or
# `backend/` source. Frontend is excluded entirely; it has its own image.
#
# Cache-bust: 2026-05-10 — forces Railway to invalidate its content-addressed
# source snapshot. Empty commits do not change the git tree SHA, so Railway
# keeps replaying the snapshot from before the Root Directory change. Any
# real file edit (like this comment) flips the tree hash and triggers a
# fresh archive that includes docs/ at the repo root.
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Python
__pycache__
*.pyc
*.pyo
*.egg-info
.eggs
*.egg
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
.tox
venv
.venv
env

# Node / Frontend (entire tree — backend image doesn't need it)
frontend
node_modules
npm-debug.log
yarn-error.log
.pnpm-debug.log
.vite
dist
build
.eslintcache

# IDE
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
desktop.ini

# Logs
logs
*.log

# Secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Local data
postgres_data
redis_data
uploads
backend/uploads
backend/temp

# Backend tests + caches (kept out of prod image)
backend/tests
backend/htmlcov
backend/.pytest_cache
backend/.mypy_cache
backend/.ruff_cache
backend/.coverage
backend/memory_audit_report.html
backend/run_memory_audit.py

# Docs we deliberately keep:
#   docs/                 (Copilot RAG curated corpus — REQUIRED in image)
# Repo-level markdown docs that bloat the image without being read by the app:
README.md
CHANGELOG.md
SECURITY.md
ONBOARDING_GUIDE.md
DEPLOYMENT_PLAN.md
SERVER_DEPLOYMENT_GUIDE.md
FOUNDATION_AUDIT.md
FULL_PROJECT_AUDIT.md
AUDIT_*.md
CHECKPOINT_*.md
STRATUM_AI_*.md
STRATUM_AI_*.html
Stratum-*.html
*.xlsx
*.zip
history.md

# Stray screenshots / images at repo root
*.png
*.jpg
*.jpeg

# CI / CD
.circleci
.github

# Docker / Make
Dockerfile*
docker-compose*
.dockerignore
Makefile
backend/Makefile

# Misc backend tooling not needed in image
scripts/seed-data.sql
scripts/load_datasets.py
backend/fix_alembic_version.py.bak
