# =============================================================================
# Stratum AI - Coverage Configuration
# =============================================================================
# Run with: pytest --cov=app --cov-config=.coveragerc

[run]
source = app
branch = True
omit =
    */tests/*
    */__pycache__/*
    */migrations/*
    */alembic/*
    app/main.py
    app/workers/celery_app.py

[report]
# Minimum coverage percentage required.
#
# This gate measures app/ coverage from the *unit* suite only (the CI coverage
# step runs `pytest tests/unit`), so it can't approach the 90% aspirational
# target for core/ — integration tests, which exercise the API/services layer,
# are run and gated separately. The previous 90% value never actually passed;
# it was masked because Backend CI failed earlier (formatting) and never
# reached this step. Set a realistic floor at the current baseline (~32.8%) and
# ratchet it up as unit coverage grows, rather than block CI on an unmet target.
# Ratchet history: 30 -> 33 (pii_hasher + rfm_segmenter) -> 34 (ab_power_analysis
# + distributed_dedupe) -> 34.8 (ai_reports + creative_scoring + churn_prevention)
# -> 35.4 (audience_lifecycle + predictive_budget) -> 36.0 (cross_platform_optimizer
# 91% + unified_notifications 90%; measured 36.03%). See #342.
fail_under = 36.0

# Show missing line numbers
show_missing = True

# Exclude lines from coverage
exclude_lines =
    # Skip type checking blocks
    pragma: no cover
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:

    # Skip abstract methods
    @abstractmethod

    # Skip defensive assertions
    raise NotImplementedError
    raise AssertionError

    # Skip debug code
    if __name__ == .__main__.:
    if settings.DEBUG:

    # Skip ellipsis (protocol stubs)
    \.\.\.

precision = 2

[html]
directory = htmlcov
title = Stratum AI Backend Coverage Report

[xml]
output = coverage.xml
