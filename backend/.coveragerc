# =============================================================================
# Stratum AI - Coverage Configuration
# =============================================================================
# Run with: pytest --cov=app --cov-config=.coveragerc

[run]
source = app
branch = True
omit =
    */tests/*
    */__pycache__/*
    */migrations/*
    */alembic/*
    app/main.py
    app/workers/celery_app.py

[report]
# Minimum coverage percentage required.
#
# This gate measures app/ coverage from the *unit* suite only (the CI coverage
# step runs `pytest tests/unit`), so it can't approach the 90% aspirational
# target for core/ — integration tests, which exercise the API/services layer,
# are run and gated separately. The previous 90% value never actually passed;
# it was masked because Backend CI failed earlier (formatting) and never
# reached this step. Set a realistic floor at the current baseline (~32.8%) and
# ratchet it up as unit coverage grows, rather than block CI on an unmet target.
# Ratchet history: 30 -> 33 (pii_hasher + rfm_segmenter) -> 34 (ab_power_analysis
# + distributed_dedupe) -> 34.8 (ai_reports + creative_scoring + churn_prevention)
# -> 35.4 (audience_lifecycle + predictive_budget) -> 36.0 (cross_platform_optimizer
# + unified_notifications) -> 36.2 (emq_calculation + ltv_forecasting) -> 36.7
# (signal_recovery + goal_tracking) -> 36.9 (attribution_confidence) -> 37.0
# (nl_filters) -> 37.2 (anomaly_narratives) -> 37.9 (signal_health + trust_gate
# core, competitor_intel, event_mapper, ab_testing; measured 37.90% for the
# 15-19 subset, higher with trust_gate) -> 38.0 (recommend engine + feature
# flags; full unit suite measured 38.11%) -> 38.7 (conversion latency +
# creative performance batches measured 38.70%; audience insights, budget
# reallocation, and EMQ measurement batches land on top) -> 40.8 (competitor
# benchmarking, offline conversions, mock client, market proxy batches; full
# unit suite measured 40.81%, plus 2 latent crash fixes) -> 41.7 (ML modules:
# ltv_predictor + creative_lifecycle + explainability; measured 41.71% with
# ltv_predictor in, explainability lands on top, plus 3 missing-import
# fixes) -> 42.3 (core analytics: anomalies + fatigue + collaborative
# annotations; full unit suite measured 42.30%) -> 42.5 (CAPI data quality
# analyzer + knowledge graph auto-insights; measured 42.50% with data
# quality in, knowledge graph lands on top) -> 43.0 (embed security service
# + exception hierarchy + tenant context RBAC; full unit suite measured
# 43.05%) -> 43.1 (schema validators: client + embed widgets, CSRF
# middleware; full unit suite measured 43.19%) -> 43.4 (stratum autopilot
# rule engine; full unit suite measured 43.47%, plus 2 latent Trust Engine
# crash fixes). See #342.
fail_under = 43.4

# Show missing line numbers
show_missing = True

# Exclude lines from coverage
exclude_lines =
    # Skip type checking blocks
    pragma: no cover
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:

    # Skip abstract methods
    @abstractmethod

    # Skip defensive assertions
    raise NotImplementedError
    raise AssertionError

    # Skip debug code
    if __name__ == .__main__.:
    if settings.DEBUG:

    # Skip ellipsis (protocol stubs)
    \.\.\.

precision = 2

[html]
directory = htmlcov
title = Stratum AI Backend Coverage Report

[xml]
output = coverage.xml
