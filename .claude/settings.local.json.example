{
  "_comment": "Personal overrides — copy to settings.local.json (gitignored). Use this for your local model preference, extra permissions, or experimental hooks.",
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Bash(psql:*)",
      "Bash(redis-cli:*)"
    ]
  },
  "env": {
    "STRATUM_LOG_LEVEL": "DEBUG"
  }
}
